{
  "Rainbow": {
    "r": "x+f",
    "g": "y+f*2",
    "b": "(x^y)+f*3"
  },

  "Fire": {
    "r": "x*y+f",
    "g": "x+f",
    "b": "f"
  },

  "Ocean": {
    "r": "f",
    "g": "y+f",
    "b": "x+y+f"
  },

  "Neon": {
    "r": "sin(x/5+f)*255",
    "g": "sin(y/5+f)*255",
    "b": "sin((x+y)/10+f)*255"
  }
}